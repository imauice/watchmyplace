{
  "name": "watchmyplace-backend-nest",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS TypeScript backend for WatchMyPlace ORMF v1",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "node --watch -r ts-node/register src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker:open-meteo:once": "node dist/workers/run.js open-meteo",
    "worker:impact:once": "node dist/workers/run.js impact",
    "worker:notification:once": "node dist/workers/run.js notification",
    "pipeline:once": "node dist/workers/run.js pipeline"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-fastify": "^11.1.9",
    "firebase-admin": "^13.6.0",
    "mongoose": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "multer": "^2.0.2",
    "uuid": "^11.1.1"
  }
}
